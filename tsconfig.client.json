{
    "extends": "./src/tsconfig-base.json",
    "compilerOptions": {
        // noEmit prevents the default tsc from building this--we use webpack instead
        "noEmit": true,
        "rootDir": "src",
        "module": "ESNext",
        "lib": [
            "ES2019",
            "dom"
        ],
        "jsx": "react"
    },
    "exclude": [
        "temp"
    ]
}

{
    "name": "prrompt",
    "type": "module",
    "displayName": "Prrompt",
    "description": "Interactive notebook environment for orchestrating TypeScript AI agents.",
    "version": "0.1.0",
    "engines": {
        "vscode": "^1.62.0"
    },
    "publisher": "prrompt",
    "author": {
        "name": "Prrompt"
    },
    "license": "MIT",
    "preview": true,
    "icon": "resources/icons/logo.png",
    "keywords": [
        "notebook",
        "AI",
        "agents",
        "typescript"
    ],
    "categories": [
        "Other",
        "Notebooks"
    ],
    "capabilities": {
        "untrustedWorkspaces": {
            "supported": true
        },
        "virtualWorkspaces": true
    },
    "activationEvents": [
        "onNotebook:prr-notebook",
        "onCommand:prr.notebook.new",
        "onCommand:prr.notebook.newREPL"
    ],
    "main": "./out/extension/index.cjs",
    "contributes": {
        "commands": [
            {
                "category": "Notebook",
                "command": "prr.notebook.new",
                "title": "Prrompt Notebook"
            },
            {
                "category": "Notebook",
                "command": "prr.notebook.newREPL",
                "title": "Open Prrompt REPL"
            },
            {
                "category": "Notebook",
                "icon": "$(bug)",
                "command": "prr.notebook.debug",
                "shortTitle": "Debug",
                "title": "Debug Notebook",
                "enablement": "notebookType == 'prr-notebook' && isWorkspaceTrusted"
            },
            {
                "category": "Notebook",
                "icon": "$(debug-restart)",
                "command": "prr.kernel.restart",
                "shortTitle": "Restart",
                "title": "Restart Kernel",
                "enablement": "notebookType == 'prr-notebook' && isWorkspaceTrusted"
            },
            {
                "command": "prr.notebook.runAndDebugCell",
                "title": "Debug Cell",
                "icon": "$(debug-alt-small)",
                "category": "Notebook",
                "enablement": "notebookType == 'prr-notebook' && isWorkspaceTrusted"
            }
        ],
        "menus": {
            "commandPalette": [
                {
                    "command": "prr.notebook.new",
                    "title": "New Prrompt Notebook",
                    "group": "Notebook"
                },
                {
                    "command": "prr.notebook.debug",
                    "when": "false"
                },
                {
                    "command": "prr.notebook.runAndDebugCell",
                    "when": "false"
                },
                {
                    "command": "prr.kernel.restart",
                    "when": "false && notebookType == 'prr-notebook' && isWorkspaceTrusted"
                }
            ],
            "notebook/cell/execute": [
                {
                    "command": "prr.notebook.runAndDebugCell",
                    "when": "notebookType == 'prr-notebook' && isWorkspaceTrusted && notebookCellType == code"
                }
            ],
            "editor/title": [
                {
                    "command": "prr.kernel.restart",
                    "group": "navigation@1",
                    "when": "notebookType == 'prr-notebook' && isWorkspaceTrusted"
                },
                {
                    "command": "prr.notebook.debug",
                    "group": "navigation@3",
                    "when": "notebookType == 'prr-notebook' && isWorkspaceTrusted"
                }
            ],
            "file/newFile": [
                {
                    "command": "prr.notebook.new"
                }
            ]
        },
        "notebooks": [
            {
                "type": "prr-notebook",
                "displayName": "Prrompt Notebook",
                "selector": [
                    {
                        "filenamePattern": "*.nnb"
                    }
                ]
            }
        ],
        "configuration": {
            "type": "object",
            "title": "Prrompt",
            "properties": {
                "prrompt.disablePseudoTerminal": {
                    "type": "boolean",
                    "default": false,
                    "description": "Disable pseudo terminal for shell cells.",
                    "scope": "machine"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "node build/esbuild.js --production",
        "build": "node build/esbuild.js --production",
        "dev": "node build/esbuild.js --watch",
        "compile:extension:watch": "tsc --watch -p ./ --noEmit",
        "lint": "eslint src/extension --ext ts",
        "package": "vsce package --yarn -o prrompt.vsix",
        "test": "node ./out/test/runTest.js",
        "download-api": "vscode-dts dev",
        "postdownload-api": "vscode-dts main"
    },
    "dependencies": {
        "@xterm/xterm": "^5.5.0",
        "error-stack-parser": "^2.1.4",
        "get-port": "^7.2.0",
        "node-pty": "^1.1.0",
        "profoundjs-node-pty": "^2.0.4",
        "shell-quote": "^1.8.4",
        "source-map": "^0.7.6",
        "uuid": "^14.0.1",
        "ws": "^8.21.0",
        "yargs": "^18.0.0"
    },
    "devDependencies": {
        "@types/bun": "^1.3.14",
        "@types/mocha": "^10.0.10",
        "@types/node": "^26.0.0",
        "@types/shell-quote": "^1.7.5",
        "@types/vscode-notebook-renderer": "^1.72.4",
        "@types/vscode-webview": "^1.57.5",
        "@types/ws": "^8.18.1",
        "@types/yargs": "^17.0.35",
        "@typescript-eslint/eslint-plugin": "^8.62.0",
        "@typescript-eslint/parser": "^8.62.0",
        "@vscode/debugprotocol": "^1.68.0",
        "@vscode/dts": "^0.4.1",
        "@vscode/test-electron": "^3.0.0",
        "concurrently": "^10.0.3",
        "esbuild": "^0.28.1",
        "eslint": "^10.5.0",
        "eslint-config-airbnb": "^18.2.1",
        "eslint-config-prettier": "^8.10.2",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jsdoc": "^63.0.7",
        "eslint-plugin-no-null": "^1.0.2",
        "eslint-plugin-prefer-arrow": "^1.2.3",
        "eslint-plugin-prettier": "^3.4.1",
        "glob": "^13.0.6",
        "mocha": "^11.7.6",
        "prettier": "^3.8.4"
    }
}
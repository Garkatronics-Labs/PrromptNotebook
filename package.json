{
    "name": "prrompt",
    "displayName": "Prrompt",
    "description": "Interactive notebook environment for orchestrating TypeScript AI agents.",
    "version": "0.1.0",
    "engines": {
        "vscode": "^1.62.0"
    },
    "publisher": "prrompt",
    "author": { "name": "Prrompt" },
    "license": "MIT",
    "preview": true,
    "icon": "resources/icons/logo.png",
    "keywords": ["notebook", "AI", "agents", "typescript"],
    "categories": ["Other", "Notebooks"],
    "capabilities": {
        "untrustedWorkspaces": { "supported": true },
        "virtualWorkspaces": true
    },
    "activationEvents": [
        "onNotebook:prr-notebook",
        "onCommand:prr.notebook.new",
        "onCommand:prr.notebook.newREPL"
    ],
    "main": "./out/extension/index.js",
    "contributes": {
        "commands": [
            {
                "category": "Notebook",
                "command": "prr.notebook.new",
                "title": "Prrompt Notebook"
            },
            {
                "category": "Notebook",
                "command": "prr.notebook.newREPL",
                "title": "Open Prrompt REPL"
            },
            {
                "category": "Notebook",
                "icon": "$(bug)",
                "command": "prr.notebook.debug",
                "shortTitle": "Debug",
                "title": "Debug Notebook",
                "enablement": "notebookType == 'prr-notebook' && isWorkspaceTrusted"
            },
            {
                "category": "Notebook",
                "icon": "$(debug-restart)",
                "command": "prr.kernel.restart",
                "shortTitle": "Restart",
                "title": "Restart Kernel",
                "enablement": "notebookType == 'prr-notebook' && isWorkspaceTrusted"
            },
            {
                "command": "prr.notebook.runAndDebugCell",
                "title": "Debug Cell",
                "icon": "$(debug-alt-small)",
                "category": "Notebook",
                "enablement": "notebookType == 'prr-notebook' && isWorkspaceTrusted"
            }
        ],
        "menus": {
            "commandPalette": [
                {
                    "command": "prr.notebook.new",
                    "title": "New Prrompt Notebook",
                    "group": "Notebook"
                },
                { "command": "prr.notebook.debug", "when": "false" },
                { "command": "prr.notebook.runAndDebugCell", "when": "false" },
                {
                    "command": "prr.kernel.restart",
                    "when": "false && notebookType == 'prr-notebook' && isWorkspaceTrusted"
                }
            ],
            "notebook/cell/execute": [
                {
                    "command": "prr.notebook.runAndDebugCell",
                    "when": "notebookType == 'prr-notebook' && isWorkspaceTrusted && notebookCellType == code"
                }
            ],
            "editor/title": [
                {
                    "command": "prr.kernel.restart",
                    "group": "navigation@1",
                    "when": "notebookType == 'prr-notebook' && isWorkspaceTrusted"
                },
                {
                    "command": "prr.notebook.debug",
                    "group": "navigation@3",
                    "when": "notebookType == 'prr-notebook' && isWorkspaceTrusted"
                }
            ],
            "file/newFile": [
                { "command": "prr.notebook.new" }
            ]
        },
        "notebooks": [
            {
                "type": "prr-notebook",
                "displayName": "Prrompt Notebook",
                "selector": [{ "filenamePattern": "*.nnb" }]
            }
        ],
        "configuration": {
            "type": "object",
            "title": "Prrompt",
            "properties": {
                "prrompt.disablePseudoTerminal": {
                    "type": "boolean",
                    "default": false,
                    "description": "Disable pseudo terminal for shell cells.",
                    "scope": "machine"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run build",
        "dev": "concurrently -r npm:compile:extension:watch npm:compile:client:watch",
        "build": "webpack --config=build/webpack/webpack.config.js --mode=production",
        "compile:extension:watch": "tsc --watch -p ./",
        "compile:client:watch": "webpack --config=build/webpack/webpack.client.config.js --watch",
        "compile:extension:webpack": "webpack --config=build/webpack/webpack.extension.config.js",
        "lint": "eslint src/extension --ext ts && eslint build --ext js",
        "package": "vsce package --yarn -o prrompt.vsix",
        "test": "node ./out/test/runTest.js",
        "download-api": "vscode-dts dev",
        "postdownload-api": "vscode-dts main",
        "fixNodeModule": "node build/fixNodeModules.js"
    },
    "dependencies": {
        "error-stack-parser": "^2.1.4",
        "get-port": "^5.1.1",
        "node-pty": "^0.10.1",
        "profoundjs-node-pty": "^2.0.3",
        "shell-quote": "^1.7.2",
        "source-map": "^0.6.1",
        "uuid": "^8.3.2",
        "ws": "^7.5.3",
        "xterm": "^4.13.0",
        "yargs": "^17.0.1"
    },
    "devDependencies": {
        "@types/bun": "^1.3.14",
        "@types/mocha": "^9.0.0",
        "@types/node": "^14.0.1",
        "@types/shell-quote": "^1.7.1",
        "@types/uuid": "^8.3.1",
        "@types/vscode-notebook-renderer": "^1.57.9",
        "@types/vscode-webview": "^1.57.0",
        "@types/ws": "^8.5.5",
        "@types/yargs": "^17.0.2",
        "@typescript-eslint/eslint-plugin": "^4.29.0",
        "@typescript-eslint/parser": "^4.29.0",
        "concurrently": "^5.2.0",
        "copy-webpack-plugin": "^9.0.1",
        "css-loader": "^3.5.3",
        "eslint": "^7.32.0",
        "eslint-config-airbnb": "^18.2.1",
        "eslint-config-prettier": "^8.3.0",
        "eslint-plugin-import": "^2.23.4",
        "eslint-plugin-jsdoc": "^36.0.6",
        "eslint-plugin-no-null": "^1.0.2",
        "eslint-plugin-prefer-arrow": "^1.2.3",
        "eslint-plugin-prettier": "^3.4.0",
        "fork-ts-checker-webpack-plugin": "^6.2.10",
        "glob": "^7.1.6",
        "mocha": "^9.0.3",
        "prettier": "^2.3.2",
        "style-loader": "^1.2.1",
        "svg-inline-loader": "^0.8.2",
        "thread-loader": "^2.1.3",
        "ts-loader": "^9.6.2",
        "url-loader": "^4.1.0",
        "vscode-debugprotocol": "^1.48.0",
        "vscode-dts": "^0.3.1",
        "vscode-test": "^1.4.0",
        "webpack": "^5.38.1",
        "webpack-bundle-analyzer": "^3.9.0",
        "webpack-cli": "^4.7.2",
        "webpack-fix-default-import-plugin": "^1.0.3",
        "xterm-addon-serialize": "^0.5.0"
    }
}